BET_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/bet
BET_JWT_SECRET=replace-this-in-non-dev
BET_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

# Python bridge/runtime paths. If unset, the backend will try repo-local defaults
# and warn at startup when they do not exist.
BET_PENALTYBLOG_PYTHON=/absolute/path/to/bet/penaltyblog/.venv/bin/python
BET_PENALTYBLOG_BRIDGE=/absolute/path/to/bet/betfront/scripts/penaltyblog_bridge.py
BET_SOCCERDATA_PYTHON=/absolute/path/to/bet/soccerdata/.venv/bin/python
BET_SOCCERDATA_BRIDGE=/absolute/path/to/bet/betfront/scripts/soccerdata_bridge.py
BET_ODDSHARVESTER_PYTHON=/absolute/path/to/bet/OddsHarvester/.venv/bin/python
